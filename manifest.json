{
    "manifest_version": 3,          
  "name": "Clarify",
  "version": "1.0",
  "description": "Explains selected text in context using AI",
  "permissions": ["activeTab", "scripting", "storage"],            
  "action": {
    "default_popup": "popup.html"         
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],             
      "js": ["content.js"],                  
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"           
  }
}